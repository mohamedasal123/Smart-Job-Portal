APP_NAME="Smart Job Portal"
# Use APP_ENV=production and APP_DEBUG=false in production.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use LOG_LEVEL=warning or error in production.
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_job
DB_USERNAME=root
DB_PASSWORD=

# Local development keeps sessions/cache on disk so CSRF/login can start even
# before the database session/cache tables are ready. Use database/redis in prod.
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Use SESSION_ENCRYPT=true in production.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:5173,127.0.0.1:3000,localhost:5173,localhost:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:5173,http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

AI_ENGINE_URL=http://127.0.0.1:8001
# Generate a strong random value for both backend and Ai/.env (must match).
# Example: php -r "echo bin2hex(random_bytes(32));"
AI_ENGINE_KEY=
FRONTEND_URL=http://127.0.0.1:5173

VITE_APP_NAME="${APP_NAME}"
